# Local docker Postgres (default). Ignored when DATABASE_URL is set.
POSTGRES_DB=tch_financials
POSTGRES_USER=tch
POSTGRES_PASSWORD=tch

# Hosted Postgres, e.g. Supabase. Use the SESSION pooler URI (port 5432) from
# Supabase → Project Settings → Database → Connection string, and keep
# sslmode=require. Do NOT use the transaction pooler (port 6543) with Django.
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

DJANGO_SECRET_KEY=dev-secret
DJANGO_DEBUG=1

VITE_API_BASE=http://localhost:8000/api
