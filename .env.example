# Supabase Postgres — used by scripts/db_backup.sh. Use the SESSION pooler URI
# (port 5432) from Supabase → Project Settings → Database → Connection string,
# and keep sslmode=require. The direct db.<ref>.supabase.co host is IPv6-only.
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# Frontend Supabase auth — copy these into frontend/.env.local (Next.js reads
# env from the frontend directory, not the repo root).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public URL of the frontend — used to build Supabase invite redirectTo links.
# Change to your production domain when deploying.
APP_URL=http://localhost:5050

# Resend — sends user invite emails from the backend.
# Use a From address on a domain verified in your Resend account
# (e.g. "TCH Financials <noreply@yourdomain.com>").
# Falls back to beth.t@example.com only if unset (may fail once a custom domain is verified).
RESEND_API_KEY=
RESEND_FROM_EMAIL=
